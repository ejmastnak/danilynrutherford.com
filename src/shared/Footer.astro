---
import FooterLink from '@/components/FooterLink.astro'
import { TinaMarkdown } from "tinacms/dist/rich-text";
import client from "@tina/__generated__/client";

interface Props {
  classes: string
}
const { classes } = Astro.props as Props;

const content = await client.queries.myFooter({ relativePath: "index.json" });
const footer = content.data.footer;
---

<div class={`bg-theme-darkgreen text-white pt-12 pb-16 px-8 overflow-x-auto ${classes ? classes : ''}`} >
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center gap-y-5 gap-x-2">

    <div class="h-fit text-center sm:text-left">
      <a href="/" class="hover:underline text-3xl">{footer.name}</a>
    </div>

    <!-- Social icons -->
    <ul class="grid grid-flow-col grid-rows-2 xs:grid-rows-1 gap-x-4 gap-y-2 items-center sm:ml-auto">

      <!-- Bluesky -->
      <li class="bg-[#0a7aff] hover:outline hover:outline hover:outline-2 hover:outline-[#0a7aff] w-10 h-10 rounded-full grid place-items-center"><a href={footer.blueskyLink}><svg width="28" height="28" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M6.3,4.2c2.3,1.7,4.8,5.3,5.7,7.2.9-1.9,3.4-5.4,5.7-7.2,1.7-1.3,4.3-2.2,4.3.9s-.4,5.2-.6,5.9c-.7,2.6-3.3,3.2-5.6,2.8,4,.7,5.1,3,2.9,5.3-5,5.2-6.7-2.8-6.7-2.8,0,0-1.7,8-6.7,2.8-2.2-2.3-1.2-4.6,2.9-5.3-2.3.4-4.9-.3-5.6-2.8-.2-.7-.6-5.3-.6-5.9,0-3.1,2.7-2.1,4.3-.9h0Z"></path></svg><span class="sr-only">Bluesky</span></a></li>

      <!-- Instagram -->
      <li class="bg-[#f00075] hover:outline hover:outline hover:outline-2 hover:outline-[#f00075] w-10 h-10 rounded-full grid place-items-center"><a href={footer.instagramLink}><svg width="28" height="28" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M12,4.622c2.403,0,2.688,0.009,3.637,0.052c0.877,0.04,1.354,0.187,1.671,0.31c0.42,0.163,0.72,0.358,1.035,0.673 c0.315,0.315,0.51,0.615,0.673,1.035c0.123,0.317,0.27,0.794,0.31,1.671c0.043,0.949,0.052,1.234,0.052,3.637 s-0.009,2.688-0.052,3.637c-0.04,0.877-0.187,1.354-0.31,1.671c-0.163,0.42-0.358,0.72-0.673,1.035 c-0.315,0.315-0.615,0.51-1.035,0.673c-0.317,0.123-0.794,0.27-1.671,0.31c-0.949,0.043-1.233,0.052-3.637,0.052 s-2.688-0.009-3.637-0.052c-0.877-0.04-1.354-0.187-1.671-0.31c-0.42-0.163-0.72-0.358-1.035-0.673 c-0.315-0.315-0.51-0.615-0.673-1.035c-0.123-0.317-0.27-0.794-0.31-1.671C4.631,14.688,4.622,14.403,4.622,12 s0.009-2.688,0.052-3.637c0.04-0.877,0.187-1.354,0.31-1.671c0.163-0.42,0.358-0.72,0.673-1.035 c0.315-0.315,0.615-0.51,1.035-0.673c0.317-0.123,0.794-0.27,1.671-0.31C9.312,4.631,9.597,4.622,12,4.622 M12,3 C9.556,3,9.249,3.01,8.289,3.054C7.331,3.098,6.677,3.25,6.105,3.472C5.513,3.702,5.011,4.01,4.511,4.511 c-0.5,0.5-0.808,1.002-1.038,1.594C3.25,6.677,3.098,7.331,3.054,8.289C3.01,9.249,3,9.556,3,12c0,2.444,0.01,2.751,0.054,3.711 c0.044,0.958,0.196,1.612,0.418,2.185c0.23,0.592,0.538,1.094,1.038,1.594c0.5,0.5,1.002,0.808,1.594,1.038 c0.572,0.222,1.227,0.375,2.185,0.418C9.249,20.99,9.556,21,12,21s2.751-0.01,3.711-0.054c0.958-0.044,1.612-0.196,2.185-0.418 c0.592-0.23,1.094-0.538,1.594-1.038c0.5-0.5,0.808-1.002,1.038-1.594c0.222-0.572,0.375-1.227,0.418-2.185 C20.99,14.751,21,14.444,21,12s-0.01-2.751-0.054-3.711c-0.044-0.958-0.196-1.612-0.418-2.185c-0.23-0.592-0.538-1.094-1.038-1.594 c-0.5-0.5-1.002-0.808-1.594-1.038c-0.572-0.222-1.227-0.375-2.185-0.418C14.751,3.01,14.444,3,12,3L12,3z M12,7.378 c-2.552,0-4.622,2.069-4.622,4.622S9.448,16.622,12,16.622s4.622-2.069,4.622-4.622S14.552,7.378,12,7.378z M12,15 c-1.657,0-3-1.343-3-3s1.343-3,3-3s3,1.343,3,3S13.657,15,12,15z M16.804,6.116c-0.596,0-1.08,0.484-1.08,1.08 s0.484,1.08,1.08,1.08c0.596,0,1.08-0.484,1.08-1.08S17.401,6.116,16.804,6.116z"></path></svg><span class="sr-only">Instagram</span></a></li>


      <!-- X -->
      <li class="bg-[#000000] hover:outline hover:outline hover:outline-2 hover:outline-[#000000] w-10 h-10 rounded-full grid place-items-center"><a href={footer.xLink}><svg width="28" height="28" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M13.982 10.622 20.54 3h-1.554l-5.693 6.618L8.745 3H3.5l6.876 10.007L3.5 21h1.554l6.012-6.989L15.868 21h5.245l-7.131-10.378Zm-2.128 2.474-.697-.997-5.543-7.93H8l4.474 6.4.697.996 5.815 8.318h-2.387l-4.745-6.787Z"></path></svg><span class="sr-only">X</span></a></li>

      <!-- Facebook -->
      <li class="bg-[#0866ff] hover:outline hover:outline hover:outline-2 hover:outline-[#0866ff] w-10 h-10 rounded-full grid place-items-center"><a href={footer.facebookLink}><svg width="28" height="28" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M12 2C6.5 2 2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7C18.3 21.1 22 17 22 12c0-5.5-4.5-10-10-10z"></path></svg><span class="sr-only">Facebook</span></a></li>

      <!-- Threads -->
      <li class="bg-[#000000] hover:outline hover:outline hover:outline-2 hover:outline-[#000000] w-10 h-10 rounded-full grid place-items-center"><a href={footer.threadsLink}><svg width="28" height="28" viewBox="0 0 24 24" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"></path></svg><span class="sr-only">Threads</span></a></li>

      <!-- LinkedIn -->
      <li class="bg-[#0966c2] hover:outline hover:outline hover:outline-2 hover:outline-[#0966c2] w-10 h-10 rounded-full grid place-items-center"><a href={footer.linkedinLink}><svg class="w-5 h-5" viewBox="0 0 32 32" version="1.1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="#ffffff"><path d="M23.984 15.844c-0.438-0.501-1.19-0.751-2.254-0.751-1.378 0-2.317 0.438-2.881 1.19-0.564 0.814-0.814 1.941-0.814 3.382v10.959c0 0.188-0.063 0.376-0.25 0.564-0.125 0.125-0.376 0.25-0.564 0.25h-5.761c-0.188 0-0.376-0.125-0.564-0.25-0.125-0.188-0.251-0.376-0.251-0.564v-20.227c0-0.188 0.125-0.376 0.251-0.564 0.188-0.125 0.376-0.251 0.564-0.251h5.573c0.188 0 0.376 0.063 0.501 0.125s0.188 0.251 0.25 0.438c0 0.188 0.063 0.376 0.063 0.438s0 0.251 0 0.501c1.44-1.378 3.382-2.004 5.699-2.004 2.693 0 4.759 0.626 6.262 1.941 1.503 1.378 2.254 3.319 2.254 5.949v13.652c0 0.188-0.063 0.376-0.25 0.564-0.125 0.125-0.376 0.25-0.564 0.25h-5.886c-0.188 0-0.376-0.125-0.564-0.25-0.125-0.188-0.25-0.376-0.25-0.564v-12.337c0-1.065-0.188-1.879-0.564-2.442zM6.638 6.137c-0.751 0.751-1.691 1.127-2.755 1.127s-2.004-0.376-2.755-1.127c-0.751-0.751-1.127-1.628-1.127-2.755 0-1.065 0.376-1.941 1.127-2.693s1.691-1.19 2.755-1.19c1.065 0 2.004 0.438 2.755 1.19s1.127 1.628 1.127 2.693c0 1.127-0.376 2.004-1.127 2.755zM7.577 10.396v20.227c0 0.188-0.125 0.376-0.25 0.564-0.188 0.125-0.376 0.25-0.564 0.25h-5.761c-0.188 0-0.376-0.125-0.564-0.25-0.125-0.188-0.251-0.376-0.251-0.564v-20.227c0-0.188 0.125-0.376 0.251-0.564 0.188-0.125 0.376-0.251 0.564-0.251h5.761c0.188 0 0.376 0.125 0.564 0.251 0.125 0.188 0.25 0.376 0.25 0.564z"></path></svg><span class="sr-only">LinkedIn</span></a></li>

    </ul>

  </div>

</div>

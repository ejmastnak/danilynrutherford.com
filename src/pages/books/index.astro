---
import client from "@tina/__generated__/client";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Books from "@tina/pages/Books/Index.tsx";
import { optimizeTinaImages } from '@/lib/optimizeTinaImages';

const content = await client.queries.myBooksPage({ relativePath: "index.json" });
const head = content.data.booksPage.head;

const booksResponse = await client.queries.bookConnection();
const books = (booksResponse.data.bookConnection.edges?.map((edge) => edge.node)).sort((a, b) => b.year - a.year);

const imagesToOptimize = books.map((book, idx) => {
  return {
    srcPath: [`${idx}`, 'image'],
    altPath: [`${idx}`, 'imageAlt'],
    width: 700,
    idx: idx,
  }
});
await optimizeTinaImages(books, imagesToOptimize);
---

<BaseLayout head={head}>
  <Books books={books} {...content} client:tina />
</BaseLayout>

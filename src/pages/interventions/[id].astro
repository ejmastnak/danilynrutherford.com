---
import { getCollection } from "astro:content";
import client from "@tina/__generated__/client";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Intervention from "@tina/pages/Interventions/Id.tsx";
import { optimizeTinaImages } from '@/lib/optimizeTinaImages';

export async function getStaticPaths() {
  const interventions = await getCollection("interventions");

  return interventions.map((intervention) => ({
    params: { id: intervention.id },
    props: {
      intervention,
      getTinaProps: async () =>
        client.queries.intervention({
          relativePath: intervention.data.tinaInfo.relativePath,
        }),
    },
  }));
}

const { intervention, getTinaProps } = Astro.props;
const content = await getTinaProps();
const head = content.data.intervention.head;

await optimizeTinaImages(content, [
  {
    srcPath: ['data', 'intervention', 'featuredImage'],
    altPath: ['data', 'intervention', 'featuredImageAlt'],
    width: 800,
  },
]);

---

<BaseLayout head={head}>
  <Intervention {...content} client:tina />
</BaseLayout>

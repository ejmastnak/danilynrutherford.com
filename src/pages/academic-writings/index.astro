---
import client from "@tina/__generated__/client";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AcademicWorks from "@tina/pages/AcademicWorks/Index.tsx";
import { optimizeTinaImages } from '@/lib/optimizeTinaImages';

const content = await client.queries.myAcademicWorksPage({ relativePath: "index.json" });
const head = content.data.academicWorksPage.head;

const academicWorksResponse = await client.queries.academicWorkConnection();
const academicWorks = academicWorksResponse.data.academicWorkConnection.edges?.map((edge) => edge.node);
---


<BaseLayout head={head}>
  <AcademicWorks academicWorks={academicWorks} {...content} client:tina />
</BaseLayout>

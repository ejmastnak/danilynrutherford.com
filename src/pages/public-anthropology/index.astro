---
import client from "@tina/__generated__/client";
import { slugify } from '@src/lib/slugify.js'
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicAnthropology from "@tina/pages/PublicAnthropology/Index.tsx";
import { optimizeTinaImages } from '@/lib/optimizeTinaImages';

const content = await client.queries.myPublicAnthropologyPage({ relativePath: "index.json" });
const head = content.data.publicAnthropologyPage.head;

const reflectionResponse = await client.queries.reflectionConnection();
const reflections = reflectionResponse.data.reflectionConnection.edges?.map((edge) => edge.node);

const interventionResponse = await client.queries.interventionConnection();
const interventions = interventionResponse.data.interventionConnection.edges?.map((edge) => edge.node);

const interviewResponse = await client.queries.interviewConnection();
const interviews = interviewResponse.data.interviewConnection.edges?.map((edge) => edge.node);

const reflectionImagesToOptimize = reflections.map((item, idx) => {
  return {
    srcPath: [`${idx}`, 'featuredImage'],
    altPath: [`${idx}`, 'featuredImageAlt'],
    width: 500,
    idx: idx,
  }
});
await optimizeTinaImages(reflections, reflectionImagesToOptimize);

const headings = [
  {
    depth: 2,
    slug: slugify(content.data.publicAnthropologyPage.interventionsHeading),
    text: content.data.publicAnthropologyPage.interventionsHeading,
  },
  {
    depth: 2,
    slug: slugify(content.data.publicAnthropologyPage.interviewsHeading),
    text: content.data.publicAnthropologyPage.interviewsHeading,
  },
  {
    depth: 2,
    slug: slugify(content.data.publicAnthropologyPage.reflectionsHeading),
    text: content.data.publicAnthropologyPage.reflectionsHeading,
  }
]

---

<BaseLayout head={head} headings={headings}>
  <PublicAnthropology
    reflections={reflections}
    interventions={interventions}
    interviews={interviews}
    {...content}
    client:load
  />
</BaseLayout>
